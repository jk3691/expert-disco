import streamlit as st
import base64

# 1. SETUP: High-End UI Configuration
st.set_page_config(page_title="JROX.FUN | Mandela Series", layout="wide")

# 2. THE BACKGROUND: Loading your CERN Infographic (1000000315.png)
def set_bg_image(image_file):
    with open(image_file, "rb") as f:
        img_data = f.read()
    b64_encoded = base64.b64encode(img_data).decode()
    style = f"""
    <style>
    .stApp {{
        background-image: url("data:image/png;base64,{b64_encoded}");
        background-size: cover;
        background-attachment: fixed;
    }}
    /* Hide the Streamlit menu and footer for a cleaner 'PRO' look */
    #MainMenu {{visibility: hidden;}}
    footer {{visibility: hidden;}}
    header {{visibility: hidden;}}
    </style>
    """
    st.markdown(style, unsafe_allow_html=True)

# Call the background function
# Make sure 1000000315.png is in your main project folder!
try:
    set_bg_image("1000000315.png")
except FileNotFoundError:
    st.error("Timeline Asset (1000000315.png) not found. Upload it to the project folder.")

